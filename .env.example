# Produção — CFN-BANCO (PostgreSQL + MySQL)
# Em dev, use docker-compose.dev.yml (override), que ignora este arquivo.

# PostgreSQL (CFN-BANCO, 172.31.5.194)
POSTGRES_HOST=172.31.5.194
POSTGRES_PORT=5432
POSTGRES_USER=vivencias_admin
POSTGRES_PASSWORD=TROCAR_EM_PRODUCAO
POSTGRES_DB_CORE=db_core
POSTGRES_DB_SISTEMAS=db_sistemas

# MySQL do CNN no CFN-BANCO (consulta-profissional)
# Quando o endpoint migrar para api.cfn.org.br (projeto api-cfn),
# remover essas variáveis.
CNN_DB_HOST=172.31.5.194
CNN_DB_PORT=3306
CNN_DB_USER=cnn_readonly
CNN_DB_PASSWORD=TROCAR_EM_PRODUCAO
CNN_DB_NAME=db_list_nutricionistas

# Chave para HMAC-SHA256 do CPF armazenado (gere um segredo forte)
#   openssl rand -base64 48
CPF_HASH_SECRET=TROCAR_EM_PRODUCAO
